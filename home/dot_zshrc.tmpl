_cache_eval starship init zsh

if [[ -o interactive ]] && [[ -z "$TMUX" ]] && [[ -n "$SSH_CONNECTION" ]]; then
  # Allow scripts to disable tmux on remote machines
  if [[ -z "$SSH_TMUX_DISABLE" ]]; then
    case "$SSH_ORIGINAL_COMMAND" in
      scp*|rsync*) ;;
      *)
        tmux attach -t main || tmux new -s main
        ;;
    esac
  fi
fi
