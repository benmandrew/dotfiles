export VIRTUAL_ENV_DISABLE_PROMPT=1

# Zinit
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
[ ! -d "${ZINIT_HOME}/.git" ] && git clone https://github.com/zdharma-continuum/zinit.git "${ZINIT_HOME}"
source "${ZINIT_HOME}/zinit.zsh"

export NVM_LAZY_LOAD=true
zinit wait"0" lucid light-mode for lukechilds/zsh-nvm

autoload -Uz compinit
if [[ -z "$(find "${ZDOTDIR:-$HOME}/.zcompdump" -mmin -1440 2>/dev/null)" ]]; then
  compinit
else
  compinit -C
fi

# SSH agent
if [ -z "$SSH_AUTH_SOCK" ]; then
  eval "$(ssh-agent -s)" > /dev/null
fi
[[ -o interactive ]] && grep -slR "PRIVATE" $HOME/.ssh/ | xargs ssh-add > /dev/null 2>&1

{{ if eq .chezmoi.os "darwin" }}

export HOMEBREW_BASE="/opt/homebrew/opt"
export CC=clang
export CXX=clang++

chruby() {
  unfunction chruby
  source $HOMEBREW_BASE/chruby/share/chruby/chruby.sh
  source $HOMEBREW_BASE/chruby/share/chruby/auto.sh
  chruby "$@"
}

export PATH="$PATH:$HOME/Library/Python/3.10/bin"
export PATH="$PATH:$HOME/bin"
export PATH="$PATH:$HOME/.local/bin"
export PATH="$PATH:$HOMEBREW_BASE/openjdk/bin"
export PATH="$PATH:$HOMEBREW_BASE/llvm/bin"
export PATH="$PATH:${GOPATH:-$HOME/go}/bin"
export PATH="$PATH:$HOMEBREW_BASE/coreutils/libexec/gnubin:/usr/local/bin"
export PATH="$PATH:/Applications/Docker.app/Contents/Resources/bin"

export JAVA_DIR="$HOMEBREW_BASE/openjdk"
export JAVA_HOME="$HOMEBREW_BASE/openjdk/bin/java"

export LIBRARY_PATH="$LIBRARY_PATH:${HOMEBREW_BASE%/opt}/lib"

{{ else if eq .chezmoi.os "linux" }}

export PATH="$PATH:/usr/local/bin"
export PATH="$PATH:$HOME/.local/bin"
export PATH="$PATH:$HOME/usr/bin"
export PATH="$PATH:/usr/local/go/bin"
export PATH="$PATH:$HOME/.cargo/bin"
export PATH="$PATH:/opt/nvim-linux-x86_64/bin"

{{ end }}

export LANG="en_GB.UTF-8"
export LC_ALL="en_GB.UTF-8"

export COLORTERM=truecolor

alias vim="nvim"
export VISUAL=vim
export EDITOR="$VISUAL"

{{ if eq .chezmoi.os "darwin" }}
export PAGER=most
{{ else if eq .chezmoi.os "linux" }}
export PAGER="most -w -t4"
{{ end }}

alias ls="eza --long --group-directories-first"
alias lsa="eza --long --group-directories-first --all"
alias python="python3"

alias gst="git st"
alias gs="git st"
alias gsv="git sv"
alias gbv="git bv"
alias grv="git rv"
alias gch="git ch"
alias ga="git add -A"
alias gd="git diff"
alias gdc="git diff --cached"
alias gll="git ll"
alias gdl="git dl"
unalias gl 2>/dev/null || true

export HISTFILE="$HOME/.zsh_history"
export HISTSIZE=1000000000
export SAVEHIST=1000000000
setopt EXTENDED_HISTORY

# Claude
export MAX_THINKING_TOKENS=8000
export WORKSPACE_ROOTS="$HOME/projects"
export CLAUDE_CODE_MAX_OUTPUT_TOKENS=64000

# Cache init-script output keyed by binary mtime — regenerates only when the binary changes
_cache_eval() {
  local cmd="$1" cache="$HOME/.cache/zsh/${1}.zsh"
  local bin_path
  bin_path="$(command -v "$cmd")"
  if [[ ! -f "$cache" ]] || [[ -n "$bin_path" && "$bin_path" -nt "$cache" ]]; then
    mkdir -p "${cache:h}"
    "$@" >| "$cache"
  fi
  source "$cache"
}

_cache_eval zoxide init zsh --cmd cd

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

opam() {
  unfunction opam
  [[ -r "$HOME/.opam/opam-init/init.zsh" ]] && source "$HOME/.opam/opam-init/init.zsh" > /dev/null 2>&1
  opam "$@"
}

