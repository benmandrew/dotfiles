# remap prefix from 'C-b' to 'C-a'
unbind C-b
set-option -g prefix C-a
bind-key C-a send-prefix

set-option -a terminal-features 'xterm-256color:RGB:extkeys'
set-option -g focus-events on
set -g extended-keys on

# on: tmux sends OSC 52 to the client terminal on yank (works over SSH)
set -s set-clipboard on

# reload config file
bind r source-file ~/.tmux.conf

set -sg escape-time 0

# mirror WezTerm split/navigation bindings
bind v split-window -h -c "#{pane_current_path}"
bind s split-window -v -c "#{pane_current_path}"
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R
bind x kill-pane

# switch panes using Alt-arrow without prefix
bind -n M-Left select-pane -L
bind -n M-Right select-pane -R
bind -n M-Up select-pane -U
bind -n M-Down select-pane -D

# Enable mouse control (clickable windows, panes, resizable panes)
set -g mouse on
set -g default-terminal "tmux-256color"

# Status bar — Hacktober palette (mirrors WezTerm tab bar)
set -g status-style bg=#141414,fg=#c9c9c9
set -g window-status-style bg=#191918,fg=#c9c9c9
set -g window-status-current-style bg=#c75a22,fg=#141414,bold
set -g window-status-format " #I  #{window_name} "
set -g window-status-current-format " #I  #{window_name} "
set -g window-status-separator ""

# Pane borders: active uses Hacktober orange to match WezTerm focus highlight
set -g pane-active-border-style fg=#c75a22
set -g pane-border-style fg=#464444

set -g status-position top
set -g status-left ''
set -g status-right-length 120
set -g status-interval 5
set -g status-right "#[bg=#191918,fg=#c9c9c9] 󰒋 #{host_short}   #(~/.config/tmux/cpu.sh)%%   #(~/.config/tmux/ram.sh)  󰔟 #(uptime | sed 's/.*up //' | sed 's/,.*//' | xargs) "

# Do nothing on bell
set -g visual-activity off
set -g visual-bell off
set -g visual-silence off
setw -g monitor-activity off
set -g bell-action none

# Mouse wheel and copy mode enhancements
bind -n WheelUpPane if-shell -F -t = "#{mouse_any_flag}" "send-keys -M" "if -Ft= '#{pane_in_mode}' 'send-keys -M' 'select-pane -t=; copy-mode -e; send-keys -M'"
bind -n WheelDownPane select-pane -t= \; send-keys -M
bind -n C-WheelUpPane select-pane -t= \; copy-mode -e \; send-keys -M
bind -T copy-mode-vi    C-WheelUpPane   send-keys -X halfpage-up
bind -T copy-mode-vi    C-WheelDownPane send-keys -X halfpage-down
bind -T copy-mode-emacs C-WheelUpPane   send-keys -X halfpage-up
bind -T copy-mode-emacs C-WheelDownPane send-keys -X halfpage-down

# Use vim keybindings in copy mode
setw -g mode-keys vi

# Clipboard integration (OS-specific)
bind-key -T copy-mode-vi v send-keys -X begin-selection

{{ if eq .chezmoi.os "darwin" }}
bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel 'pbcopy'
bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel 'pbcopy'
bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel 'pbcopy'
{{ else if eq .chezmoi.os "linux" }}
bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel '~/.config/tmux/copy.sh'
bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel '~/.config/tmux/copy.sh'
bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel '~/.config/tmux/copy.sh'
{{ end }}

# Plugins
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
run '~/.tmux/plugins/tpm/tpm'
