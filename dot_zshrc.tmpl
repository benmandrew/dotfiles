# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="eastwood"

plugins=(git tmux nvm)

source $ZSH/oh-my-zsh.sh

zstyle ':omz:plugins:nvm' lazy yes


{{ if eq .chezmoi.os "darwin" }}

export HOMEBREW_BASE="/opt/homebrew/opt"
export CC=clang
export CXX=clang++

source $HOMEBREW_BASE/chruby/share/chruby/chruby.sh
source $HOMEBREW_BASE/chruby/share/chruby/auto.sh
chruby ruby-3.1.2

export PATH="$PATH:$HOME/Library/Python/3.10/bin"
export PATH="$PATH:$HOME/bin"
export PATH="$PATH:$HOMEBREW_BASE/openjdk/bin"
export PATH="$PATH:$(brew --prefix)/opt/llvm/bin"
export PATH="$PATH:$(go env GOPATH)/bin"
export PATH="$PATH:$HOMEBREW_BASE/coreutils/libexec/gnubin:/usr/local/bin:$HOMEBREW_BASE/llvm/bin"

export JAVA_DIR="$HOMEBREW_BASE/openjdk"
export JAVA_HOME="$HOMEBREW_BASE/openjdk/bin/java"

export LDFLAGS='-L/usr/local/opt/llvm/lib -Wl,-rpath,/usr/local/opt/llvm/lib'
export LIBRARY_PATH="$LIBRARY_PATH:$(brew --prefix)/lib"

{{ else if eq .chezmoi.os "linux" }}

export PATH="$PATH:/usr/local/bin"
export PATH="$PATH:$HOME/.local/bin"
export PATH="$PATH:/usr/local/go/bin"
export PATH="$PATH:$HOME/.cargo/bin"

{{ end }}

export LANG="en_GB.UTF-8"
export LC_ALL="en_GB.UTF-8"

export COLORTERM=truecolor

alias vim="nvim"
export VISUAL=vim
export EDITOR="$VISUAL"

{{ if eq .chezmoi.os "darwin" }}
export PAGER=most
{{ else if eq .chezmoi.os "linux" }}
export PAGER="most -w -t4"
{{ end }}

alias ls="eza --long --numeric --group-directories-first"
alias lsa="eza --long --numeric --group-directories-first --all"
alias python="python3"

alias gst="git st"
alias gs="git st"
alias gsv="git sv"
alias gbv="git bv"
alias grv="git rv"
alias gch="git ch"
alias ga="git add -A"
alias gd="git diff"
alias gdc="git diff --cached"
alias gll="git ll"
alias gdl="git dl"
unalias gl

export HISTFILE="$HOME/.zsh_history"
export HISTSIZE=1000000000
export SAVEHIST=1000000000
setopt EXTENDED_HISTORY

eval "$(zoxide init zsh --cmd cd)"

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

[[ ! -r '$HOME/.opam/opam-init/init.zsh' ]] || source '$HOME/.opam/opam-init/init.zsh' > /dev/null 2> /dev/null

if [ "$TMUX" = "" ]; then tmux; fi
